include "/usr/share/nano/*.nanorc"
set atblanks
set constantshow
set linenumbers
set locking
set showcursor
set softwrap
set tabsize 4
set unix
bind M-F formatter main
bind M-S linter main

extendsyntax python formatter black
extendsyntax python linter pylint -ftext --exit-zero
extendsyntax python tabgives "    "
