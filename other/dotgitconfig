# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
    name = Firepup Sixfifty
    email = firepup650@firepup650.com
    signingkey = ~/.ssh/id_ed25519
    useConfigOnly = true
[advice]
    addIgnoredFile = false
[alias]
    branches = branch -avv
    rename = branch -m
    remotes = remote -vv
    editconfig = config --global --edit
    master-to-main = branch -m master main
    pushall = !git remote -v|grep -vE 'git://|fetch|.bundle|^upstream'|sed -E 's/^([^\\t]+)\\s+.*/\\1/'|xargs -L1 -P0 git push
    find-files = "!f() { args=''; for o in "$@"; do args=\"$args --find-object=$o\"; done; git log --pretty=format:'%C(auto)%h %s' --no-show-signature $args; }; f"
[commit]
    gpgsign = true
    template = ~/.config/git/commitTemplate
[core]
    autocrlf = input
    editor = nano
[gpg]
    format = ssh
[gpg.ssh]
    allowedSignersFile = ~/.config/git/allowedSigners
[init]
    defaultBranch = main
[pull]
    ff = true
[push]
    autoSetupRemote = true
[url "ssh://git@github.com/"]
    pushInsteadOf = https://github.com/
[log]
	showSignature = true
[format]
	pretty = fuller
